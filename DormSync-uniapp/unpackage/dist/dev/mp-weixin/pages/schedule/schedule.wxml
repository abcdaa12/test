<view class="container data-v-e6e5e79f"><view class="card action-card data-v-e6e5e79f"><view class="form-title data-v-e6e5e79f">排班设置</view><view class="setting-row data-v-e6e5e79f"><text class="setting-label data-v-e6e5e79f">排班周期</text><picker class="data-v-e6e5e79f" range="{{b}}" bindchange="{{c}}" value="{{d}}"><view class="picker-value data-v-e6e5e79f">{{a}} ▾</view></picker></view><view class="setting-row data-v-e6e5e79f"><text class="setting-label data-v-e6e5e79f">参与成员</text><text class="setting-value data-v-e6e5e79f">{{e}}</text></view><button class="btn-primary data-v-e6e5e79f" bindtap="{{f}}">🔄 一键生成排班表</button></view><view class="section-title data-v-e6e5e79f">{{g}} 排班表 </view><view wx:if="{{h}}" class="empty-tip data-v-e6e5e79f"><text class="data-v-e6e5e79f">暂无排班，请点击上方按钮生成</text></view><view wx:for="{{i}}" wx:for-item="item" wx:key="d" class="card schedule-item data-v-e6e5e79f"><view class="schedule-row data-v-e6e5e79f"><text class="schedule-date data-v-e6e5e79f">{{item.a}}</text><text class="schedule-weekday data-v-e6e5e79f">{{item.b}}</text><text class="schedule-person data-v-e6e5e79f">{{item.c}}</text></view></view><view wx:if="{{j}}" class="data-v-e6e5e79f"><view class="section-title data-v-e6e5e79f">历史排班</view><view wx:for="{{k}}" wx:for-item="week" wx:key="c" class="card data-v-e6e5e79f"><view class="history-title data-v-e6e5e79f">{{week.a}}</view><view wx:for="{{week.b}}" wx:for-item="item" wx:key="d" class="schedule-row history-row data-v-e6e5e79f"><text class="schedule-date data-v-e6e5e79f">{{item.a}}</text><text class="schedule-weekday data-v-e6e5e79f">{{item.b}}</text><text class="schedule-person data-v-e6e5e79f">{{item.c}}</text></view></view></view></view>