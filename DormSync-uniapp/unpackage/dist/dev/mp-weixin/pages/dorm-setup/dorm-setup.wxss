
.page.data-v-baf89709 { min-height: 100vh; background-color: var(--bg-page);
}
.container.data-v-baf89709 { padding: 40rpx 24rpx;
}
.header-section.data-v-baf89709 { display: flex; flex-direction: column; align-items: center; padding: 60rpx 0 40rpx;
}
.header-icon.data-v-baf89709 { font-size: 80rpx; margin-bottom: 20rpx;
}
.header-title.data-v-baf89709 { font-size: 36rpx; font-weight: bold; color: var(--text-primary); margin-bottom: 12rpx;
}
.header-desc.data-v-baf89709 { font-size: 26rpx; color: var(--text-secondary);
}
