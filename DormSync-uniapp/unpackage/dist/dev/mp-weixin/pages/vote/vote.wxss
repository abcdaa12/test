
/* 表单区域 */
.form-card.data-v-6ab7a061 {
	margin-top: 24rpx;
}
.form-title.data-v-6ab7a061 {
	font-size: 32rpx;
	font-weight: bold;
	margin-bottom: 24rpx;
	color: #333;
}

/* 选项输入行 */
.option-row.data-v-6ab7a061 {
	display: flex;
	align-items: center;
	gap: 12rpx;
}
.option-input.data-v-6ab7a061 {
	flex: 1;
}
.option-del.data-v-6ab7a061 {
	color: #e74c3c;
	font-size: 32rpx;
	padding: 8rpx 16rpx;
	margin-bottom: 20rpx;
}
.option-actions.data-v-6ab7a061 {
	margin-bottom: 20rpx;
}
.add-option.data-v-6ab7a061 {
	color: #4A90D9;
	font-size: 28rpx;
}

/* 分区标题 */
.section-title.data-v-6ab7a061 {
	font-size: 30rpx;
	font-weight: bold;
	margin: 32rpx 0 16rpx;
	color: #333;
}

/* 空状态 */
.empty-tip.data-v-6ab7a061 {
	text-align: center;
	padding: 60rpx 0;
	color: #ccc;
	font-size: 28rpx;
}

/* 投票条目 */
.vote-header.data-v-6ab7a061 {
	display: flex;
	justify-content: space-between;
	align-items: center;
	margin-bottom: 16rpx;
}
.vote-title.data-v-6ab7a061 {
	font-size: 30rpx;
	font-weight: bold;
}
.vote-status.data-v-6ab7a061 {
	font-size: 24rpx;
	padding: 4rpx 16rpx;
	border-radius: 20rpx;
}
.vote-status.active.data-v-6ab7a061 {
	background-color: #e8f5e9;
	color: #4caf50;
}
.vote-status.ended.data-v-6ab7a061 {
	background-color: #f5f5f5;
	color: #999;
}

/* 投票选项 */
.vote-option.data-v-6ab7a061 {
	margin-bottom: 16rpx;
	position: relative;
}
.option-bar.data-v-6ab7a061 {
	height: 48rpx;
	background-color: #f0f0f0;
	border-radius: 8rpx;
	overflow: hidden;
}
.option-fill.data-v-6ab7a061 {
	height: 100%;
	background-color: #4A90D9;
	border-radius: 8rpx;
	transition: width 0.3s;
	opacity: 0.2;
}
.option-info.data-v-6ab7a061 {
	position: absolute;
	top: 0;
	left: 16rpx;
	right: 16rpx;
	height: 48rpx;
	display: flex;
	justify-content: space-between;
	align-items: center;
	font-size: 26rpx;
}
.option-count.data-v-6ab7a061 {
	color: #666;
	font-size: 24rpx;
}
.vote-time.data-v-6ab7a061 {
	font-size: 22rpx;
	color: #bbb;
	display: block;
	text-align: right;
	margin-top: 8rpx;
}
