
.container.data-v-6ab7a061 { min-height: 100vh; background-color: var(--bg-page); padding: 24rpx;
}
.form-card.data-v-6ab7a061 { margin-top: 24rpx;
}
.form-title.data-v-6ab7a061 { font-size: 32rpx; font-weight: bold; margin-bottom: 24rpx; color: var(--text-primary);
}
.option-row.data-v-6ab7a061 { display: flex; align-items: center; gap: 12rpx;
}
.option-input.data-v-6ab7a061 { flex: 1;
}
.option-del.data-v-6ab7a061 { color: #e74c3c; font-size: 32rpx; padding: 8rpx 16rpx; margin-bottom: 20rpx;
}
.option-actions.data-v-6ab7a061 { margin-bottom: 20rpx;
}
.add-option.data-v-6ab7a061 { color: var(--color-primary); font-size: 28rpx;
}
.setting-row.data-v-6ab7a061 { display: flex; justify-content: space-between; align-items: center; padding: 16rpx 0; margin-bottom: 20rpx;
}
.setting-label.data-v-6ab7a061 { font-size: 28rpx; color: var(--text-secondary);
}
.datetime-pick.data-v-6ab7a061 { display: flex; gap: 16rpx;
}
.picker-value.data-v-6ab7a061 { font-size: 28rpx; color: var(--color-primary);
}
.cancel-edit.data-v-6ab7a061 { display: block; text-align: center; color: var(--text-hint); font-size: 26rpx; margin-top: 16rpx;
}
.section-title.data-v-6ab7a061 { font-size: 30rpx; font-weight: bold; margin: 32rpx 0 16rpx; color: var(--text-primary);
}
.empty-tip.data-v-6ab7a061 { text-align: center; padding: 60rpx 0; color: var(--text-placeholder); font-size: 28rpx;
}

/* 投票卡片 */
.vote-item.data-v-6ab7a061 { margin-bottom: 16rpx;
}
.anonymous-card.data-v-6ab7a061 { border-left: 6rpx solid #ff9800;
}
.vote-header.data-v-6ab7a061 { display: flex; justify-content: space-between; align-items: center; margin-bottom: 16rpx;
}
.vote-title.data-v-6ab7a061 { font-size: 30rpx; font-weight: bold; color: var(--text-primary); flex: 1;
}
.vote-tags.data-v-6ab7a061 { display: flex; gap: 8rpx; align-items: center; flex-shrink: 0;
}
.vote-tag.data-v-6ab7a061 { font-size: 22rpx; padding: 2rpx 12rpx; border-radius: 16rpx;
}
.vote-tag.anonymous.data-v-6ab7a061 { background-color: #fff3e0; color: #e65100;
}
.dark-mode .vote-tag.anonymous.data-v-6ab7a061 { background-color: #3e2700; color: #ffb74d;
}
.vote-status.data-v-6ab7a061 { font-size: 24rpx; padding: 4rpx 16rpx; border-radius: 20rpx;
}
.vote-status.active.data-v-6ab7a061 { background-color: #e8f5e9; color: #4caf50;
}
.vote-status.ended.data-v-6ab7a061 { background-color: var(--bg-input); color: var(--text-hint);
}
.dark-mode .vote-status.active.data-v-6ab7a061 { background-color: #1a2a1a;
}
.vote-deadline.data-v-6ab7a061 { font-size: 24rpx; color: var(--text-hint); margin-bottom: 12rpx;
}
.vote-option.data-v-6ab7a061 { margin-bottom: 16rpx; position: relative;
}
.option-bar.data-v-6ab7a061 { height: 48rpx; background-color: var(--bg-input); border-radius: 8rpx; overflow: hidden;
}
.option-fill.data-v-6ab7a061 { height: 100%; background-color: var(--color-primary); border-radius: 8rpx; transition: width 0.3s; opacity: 0.2;
}
.option-info.data-v-6ab7a061 { position: absolute; top: 0; left: 16rpx; right: 16rpx; height: 48rpx; display: flex; justify-content: space-between; align-items: center; font-size: 26rpx; color: var(--text-primary);
}
.option-count.data-v-6ab7a061 { color: var(--text-secondary); font-size: 24rpx;
}
.option-pending.data-v-6ab7a061 {
	height: 48rpx; display: flex; align-items: center; padding: 0 16rpx;
	background: var(--bg-input); border-radius: 8rpx; font-size: 26rpx;
	color: var(--text-primary);
}
.option-pending.data-v-6ab7a061:active { background: var(--color-primary); color: #fff; opacity: 0.8;
}
.vote-footer.data-v-6ab7a061 { display: flex; justify-content: space-between; align-items: center; margin-top: 12rpx;
}
.vote-time.data-v-6ab7a061 { font-size: 22rpx; color: var(--text-placeholder);
}
.vote-actions-row.data-v-6ab7a061 { display: flex; gap: 24rpx;
}
.action-link.data-v-6ab7a061 { font-size: 24rpx; padding: 4rpx 8rpx;
}
.action-link.edit.data-v-6ab7a061 { color: var(--color-primary);
}
.action-link.delete.data-v-6ab7a061 { color: #ff4d4f;
}

/* 详情弹窗 */
.modal-mask.data-v-6ab7a061 { position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.5); display: flex; align-items: center; justify-content: center; z-index: 999;
}
.modal-content.data-v-6ab7a061 { width: 88%; background: var(--bg-card, #fff); border-radius: 20rpx; padding: 36rpx 32rpx; max-height: 80vh; overflow-y: auto;
}
.modal-header.data-v-6ab7a061 { display: flex; justify-content: space-between; align-items: center; margin-bottom: 28rpx;
}
.modal-title.data-v-6ab7a061 { font-size: 34rpx; font-weight: bold; color: var(--text-primary);
}
.modal-close.data-v-6ab7a061 { font-size: 36rpx; color: var(--text-hint); padding: 8rpx 16rpx;
}
.detail-section.data-v-6ab7a061 { margin-bottom: 8rpx;
}
.detail-row.data-v-6ab7a061 { display: flex; justify-content: space-between; align-items: center; padding: 16rpx 0; border-bottom: 1rpx solid var(--border-light);
}
.detail-label.data-v-6ab7a061 { font-size: 26rpx; color: var(--text-secondary);
}
.detail-value.data-v-6ab7a061 { font-size: 26rpx; color: var(--text-primary); font-weight: 500;
}
.anonymous-yes.data-v-6ab7a061 { color: #e65100;
}
.detail-divider.data-v-6ab7a061 { height: 1rpx; background: var(--border-color); margin: 20rpx 0;
}
.detail-options.data-v-6ab7a061 { margin-bottom: 20rpx;
}
.detail-opt.data-v-6ab7a061 { margin-bottom: 20rpx;
}
.detail-opt-header.data-v-6ab7a061 { display: flex; justify-content: space-between; margin-bottom: 8rpx;
}
.detail-opt-label.data-v-6ab7a061 { font-size: 28rpx; color: var(--text-primary); font-weight: 500;
}
.detail-opt-count.data-v-6ab7a061 { font-size: 24rpx; color: var(--color-primary);
}
.detail-opt-bar.data-v-6ab7a061 { height: 24rpx; background: var(--bg-input); border-radius: 12rpx; overflow: hidden;
}
.detail-opt-fill.data-v-6ab7a061 { height: 100%; background: var(--color-primary); border-radius: 12rpx; opacity: 0.6; transition: width 0.3s;
}
.detail-voters.data-v-6ab7a061 { margin-top: 8rpx;
}
.voter-text.data-v-6ab7a061 { font-size: 22rpx; color: var(--text-hint);
}
.detail-actions.data-v-6ab7a061 { margin-top: 16rpx;
}
.detail-tip.data-v-6ab7a061 { font-size: 24rpx; color: var(--text-hint); text-align: center; display: block; margin-bottom: 16rpx;
}
.detail-vote-btns.data-v-6ab7a061 { display: flex; flex-wrap: wrap; gap: 16rpx;
}
.detail-vote-btn.data-v-6ab7a061 { flex: 1; min-width: 40%; text-align: center; padding: 16rpx 0; background: var(--color-primary); color: #fff; border-radius: 12rpx; font-size: 26rpx;
}
.detail-vote-btn.data-v-6ab7a061:active { opacity: 0.8;
}
.voted-tip.data-v-6ab7a061 { text-align: center; padding: 24rpx 0; color: #4caf50; font-size: 28rpx;
}
