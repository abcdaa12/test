
.page.data-v-7c2ebfa5 { min-height: 100vh; background-color: var(--bg-page);
}
.user-header.data-v-7c2ebfa5 {
	background: linear-gradient(135deg, #1677FF, #4A9FFF);
	padding: 50rpx 30rpx 40rpx; display: flex; align-items: center;
}
.avatar-wrap.data-v-7c2ebfa5 {
	width: 120rpx; height: 120rpx; border-radius: 50%;
	background: rgba(255,255,255,0.3); overflow: hidden;
	display: flex; align-items: center; justify-content: center; flex-shrink: 0;
}
.avatar-img.data-v-7c2ebfa5 { width: 120rpx; height: 120rpx; border-radius: 50%;
}
.avatar-icon.data-v-7c2ebfa5 { font-size: 60rpx;
}
.user-info.data-v-7c2ebfa5 { flex: 1; margin-left: 24rpx;
}
.user-name.data-v-7c2ebfa5 { font-size: 34rpx; font-weight: bold; color: #fff; display: block; margin-bottom: 8rpx;
}
.user-sign.data-v-7c2ebfa5 { font-size: 24rpx; color: rgba(255,255,255,0.8); display: block;
}
.container.data-v-7c2ebfa5 { padding: 24rpx;
}
.login-card.data-v-7c2ebfa5 {
	background: var(--bg-card); border-radius: 16rpx; padding: 48rpx 32rpx;
	text-align: center; box-shadow: var(--shadow-card);
}
.login-tip.data-v-7c2ebfa5 { font-size: 28rpx; color: var(--text-hint); display: block; margin-bottom: 32rpx;
}
.btn-login.data-v-7c2ebfa5 { background-color: var(--color-primary); color: #fff; border-radius: 12rpx; font-size: 30rpx; height: 80rpx; line-height: 80rpx;
}
.menu-card.data-v-7c2ebfa5 {
	background: var(--bg-card); border-radius: 16rpx; overflow: hidden;
	margin-bottom: 24rpx; box-shadow: var(--shadow-card);
}
.menu-item.data-v-7c2ebfa5 {
	display: flex; align-items: center; padding: 30rpx 24rpx;
	border-bottom: 1rpx solid var(--border-light);
}
.menu-item.data-v-7c2ebfa5:last-child { border-bottom: none;
}
.menu-item.data-v-7c2ebfa5:active { background-color: var(--bg-hover);
}
.menu-icon.data-v-7c2ebfa5 { font-size: 36rpx; margin-right: 20rpx; flex-shrink: 0;
}
.menu-text.data-v-7c2ebfa5 { flex: 1; font-size: 30rpx; color: var(--text-primary);
}
.menu-arrow.data-v-7c2ebfa5 { font-size: 30rpx; color: var(--text-hint);
}
.logout-btn.data-v-7c2ebfa5 {
	margin-top: 40rpx; background: var(--bg-card); border-radius: 16rpx;
	padding: 28rpx; text-align: center; box-shadow: var(--shadow-card);
}
.logout-btn.data-v-7c2ebfa5:active { background-color: #fff5f5;
}
.logout-text.data-v-7c2ebfa5 { font-size: 30rpx; color: #ff4d4f;
}
