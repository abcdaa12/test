
.container.data-v-fe67f23b { min-height: 100vh; background-color: var(--bg-page); padding: 24rpx;
}

/* 统计卡片 */
.stats-card.data-v-fe67f23b {
	display: flex; align-items: center; justify-content: center;
	background: linear-gradient(135deg, #1677FF, #4A9FFF);
	border-radius: 16rpx; padding: 32rpx 0; margin-bottom: 24rpx;
}
.dark-mode .stats-card.data-v-fe67f23b { background: linear-gradient(135deg, #0d47a1, #1565c0);
}
.stats-item.data-v-fe67f23b { flex: 1; text-align: center;
}
.stats-value.data-v-fe67f23b { font-size: 40rpx; font-weight: bold; color: #fff; display: block;
}
.stats-label.data-v-fe67f23b { font-size: 24rpx; color: rgba(255,255,255,0.8); display: block; margin-top: 8rpx;
}
.stats-divider.data-v-fe67f23b { width: 1rpx; height: 60rpx; background: rgba(255,255,255,0.3);
}

/* 搜索栏 */
.search-bar.data-v-fe67f23b { display: flex; gap: 16rpx; margin: 24rpx 0 16rpx; align-items: center;
}
.search-input.data-v-fe67f23b {
	flex: 1; height: 68rpx; background: var(--bg-card); border: 1rpx solid var(--border-color);
	border-radius: 34rpx; padding: 0 28rpx; font-size: 26rpx; color: var(--text-primary);
}
.filter-btn.data-v-fe67f23b {
	height: 68rpx; line-height: 68rpx; padding: 0 24rpx; background: var(--bg-card);
	border: 1rpx solid var(--border-color); border-radius: 34rpx;
	font-size: 24rpx; color: var(--color-primary); white-space: nowrap;
}

/* 表单 */
.form-card.data-v-fe67f23b { margin-top: 24rpx;
}
.form-title.data-v-fe67f23b { font-size: 32rpx; font-weight: bold; margin-bottom: 24rpx; color: var(--text-primary);
}
.picker-input.data-v-fe67f23b { color: var(--text-secondary);
}
.payer-section.data-v-fe67f23b { margin-bottom: 20rpx;
}
.payer-label.data-v-fe67f23b { font-size: 28rpx; color: var(--text-secondary); display: block; margin-bottom: 12rpx;
}
.payer-list.data-v-fe67f23b { display: flex; flex-wrap: wrap; gap: 12rpx;
}
.payer-tag.data-v-fe67f23b {
	padding: 12rpx 24rpx; border-radius: 32rpx; font-size: 26rpx;
	background: var(--bg-input); color: var(--text-secondary);
	border: 1rpx solid var(--border-color);
}
.payer-active.data-v-fe67f23b {
	background: #e6f4ff; color: var(--color-primary);
	border-color: var(--color-primary);
}
.dark-mode .payer-active.data-v-fe67f23b { background: #1a2a3a;
}

/* 月份分组 */
.month-group.data-v-fe67f23b { margin-bottom: 8rpx;
}
.month-header.data-v-fe67f23b {
	display: flex; justify-content: space-between; align-items: center;
	padding: 20rpx 8rpx 12rpx; border-bottom: 1rpx solid var(--border-light);
}
.month-label.data-v-fe67f23b { font-size: 28rpx; font-weight: bold; color: var(--text-primary);
}
.month-sum.data-v-fe67f23b { font-size: 24rpx; color: var(--text-hint);
}

/* 费用条目 */
.fee-item.data-v-fe67f23b {
	display: flex; align-items: center; padding: 24rpx 16rpx;
	background: var(--bg-card); border-radius: 12rpx; margin-top: 12rpx;
}
.fee-item.data-v-fe67f23b:active { background: var(--bg-hover, #f0f0f0);
}
.fee-icon-wrap.data-v-fe67f23b {
	width: 72rpx; height: 72rpx; border-radius: 50%;
	background: #FFF3E0; display: flex; align-items: center; justify-content: center;
	margin-right: 20rpx; flex-shrink: 0;
}
.dark-mode .fee-icon-wrap.data-v-fe67f23b { background: #2a2000;
}
.fee-icon.data-v-fe67f23b { font-size: 36rpx;
}
.fee-info.data-v-fe67f23b { flex: 1; overflow: hidden;
}
.fee-title.data-v-fe67f23b { font-size: 28rpx; color: var(--text-primary); display: block; font-weight: 500;
}
.fee-sub.data-v-fe67f23b { font-size: 22rpx; color: var(--text-hint); display: block; margin-top: 6rpx;
}
.fee-right.data-v-fe67f23b { text-align: right; flex-shrink: 0; margin-left: 16rpx;
}
.fee-amount.data-v-fe67f23b { font-size: 30rpx; color: #e74c3c; font-weight: bold; display: block;
}
.fee-avg.data-v-fe67f23b { font-size: 20rpx; color: var(--text-hint); display: block; margin-top: 4rpx;
}
.empty-tip.data-v-fe67f23b { text-align: center; padding: 80rpx 0; color: var(--text-placeholder); font-size: 28rpx;
}

/* 详情弹窗 */
.modal-mask.data-v-fe67f23b {
	position: fixed; top: 0; left: 0; right: 0; bottom: 0;
	background: rgba(0,0,0,0.5); display: flex; align-items: center;
	justify-content: center; z-index: 999;
}
.modal-content.data-v-fe67f23b {
	width: 85%; background: var(--bg-card, #fff); border-radius: 20rpx;
	padding: 40rpx 32rpx; max-height: 80vh;
}
.modal-header.data-v-fe67f23b {
	display: flex; justify-content: space-between; align-items: center;
	margin-bottom: 32rpx;
}
.modal-title.data-v-fe67f23b { font-size: 34rpx; font-weight: bold; color: var(--text-primary);
}
.modal-close.data-v-fe67f23b { font-size: 36rpx; color: var(--text-hint); padding: 8rpx 16rpx;
}
.detail-row.data-v-fe67f23b {
	display: flex; justify-content: space-between; align-items: center;
	padding: 20rpx 0; border-bottom: 1rpx solid var(--border-light);
}
.detail-row.data-v-fe67f23b:last-child { border-bottom: none;
}
.detail-label.data-v-fe67f23b { font-size: 28rpx; color: var(--text-secondary);
}
.detail-value.data-v-fe67f23b { font-size: 28rpx; color: var(--text-primary); font-weight: 500;
}
.amount-highlight.data-v-fe67f23b { color: #e74c3c; font-size: 34rpx; font-weight: bold;
}
