
.page.data-v-4c1b26cf {
	min-height: 100vh;
	background-color: #f5f5f5;
}
.container.data-v-4c1b26cf {
	padding: 24rpx;
}

/* 搜索栏 */
.search-bar.data-v-4c1b26cf {
	display: flex;
	align-items: center;
	gap: 16rpx;
	margin-bottom: 24rpx;
}
.search-input-wrap.data-v-4c1b26cf {
	flex: 1;
	display: flex;
	align-items: center;
	background-color: #fff;
	border-radius: 40rpx;
	padding: 12rpx 24rpx;
	border: 1rpx solid #eee;
}
.search-icon.data-v-4c1b26cf {
	font-size: 28rpx;
	margin-right: 12rpx;
}
.search-input.data-v-4c1b26cf {
	flex: 1;
	font-size: 28rpx;
}
.filter-btn.data-v-4c1b26cf {
	background-color: #fff;
	border: 1rpx solid #1677FF;
	border-radius: 40rpx;
	padding: 12rpx 28rpx;
}
.filter-text.data-v-4c1b26cf {
	color: #1677FF;
	font-size: 26rpx;
}

/* 筛选弹窗 */
.filter-mask.data-v-4c1b26cf {
	position: fixed;
	top: 0;
	left: 0;
	right: 0;
	bottom: 0;
	background-color: rgba(0, 0, 0, 0.4);
	z-index: 100;
	display: flex;
	align-items: flex-end;
}
.filter-popup.data-v-4c1b26cf {
	background-color: #fff;
	width: 100%;
	border-radius: 24rpx 24rpx 0 0;
	padding: 40rpx 30rpx;
}
.filter-group.data-v-4c1b26cf {
	margin-bottom: 32rpx;
}
.filter-group-title.data-v-4c1b26cf {
	font-size: 28rpx;
	font-weight: bold;
	color: #333;
	display: block;
	margin-bottom: 16rpx;
}
.filter-options.data-v-4c1b26cf {
	display: flex;
	flex-wrap: wrap;
	gap: 16rpx;
}
.filter-tag.data-v-4c1b26cf {
	padding: 12rpx 32rpx;
	border-radius: 40rpx;
	font-size: 26rpx;
	background-color: #f5f5f5;
	color: #666;
}
.filter-tag.active.data-v-4c1b26cf {
	background-color: #e6f4ff;
	color: #1677FF;
	border: 1rpx solid #1677FF;
}
.filter-confirm.data-v-4c1b26cf {
	background-color: #1677FF;
	color: #fff;
	border-radius: 12rpx;
	font-size: 30rpx;
	height: 80rpx;
	line-height: 80rpx;
	margin-top: 16rpx;
}

/* 空状态 */
.empty-tip.data-v-4c1b26cf {
	text-align: center;
	padding: 80rpx 0;
	color: #ccc;
	font-size: 28rpx;
}

/* 消息条目容器 */
.msg-item-wrap.data-v-4c1b26cf {
	position: relative;
	overflow: hidden;
	margin-bottom: 16rpx;
	border-radius: 12rpx;
}
.msg-item.data-v-4c1b26cf {
	background-color: #fff;
	padding: 24rpx;
	position: relative;
	z-index: 2;
	transition: transform 0.15s ease;
	border-radius: 12rpx;
}
.msg-left.data-v-4c1b26cf {
	display: flex;
	align-items: center;
	gap: 12rpx;
	margin-bottom: 12rpx;
}
.msg-status.data-v-4c1b26cf {
	font-size: 24rpx;
	font-weight: bold;
}
.msg-status.unread.data-v-4c1b26cf {
	color: #ff4d4f;
}
.msg-status.read.data-v-4c1b26cf {
	color: #999;
}
.msg-type.data-v-4c1b26cf {
	font-size: 22rpx;
	padding: 4rpx 14rpx;
	border-radius: 20rpx;
}
.type-vote.data-v-4c1b26cf {
	background-color: #e6f4ff;
	color: #1677FF;
}
.type-task.data-v-4c1b26cf {
	background-color: #f6ffed;
	color: #52c41a;
}
.type-finance.data-v-4c1b26cf {
	background-color: #fff7e6;
	color: #fa8c16;
}
.msg-content.data-v-4c1b26cf {
	font-size: 28rpx;
	color: #333;
	display: block;
	margin-bottom: 8rpx;
}
.msg-time.data-v-4c1b26cf {
	font-size: 22rpx;
	color: #bbb;
}

/* 左滑操作按钮 */
.msg-actions.data-v-4c1b26cf {
	position: absolute;
	right: 0;
	top: 0;
	bottom: 0;
	display: flex;
	z-index: 1;
}
.action-btn.data-v-4c1b26cf {
	display: flex;
	align-items: center;
	justify-content: center;
	width: 160rpx;
	color: #fff;
	font-size: 24rpx;
}
.mark-read.data-v-4c1b26cf {
	background-color: #1677FF;
}
.delete-btn.data-v-4c1b26cf {
	background-color: #ff4d4f;
}
