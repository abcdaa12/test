
/* 页面容器 */
.page.data-v-1cf27b2a {
	min-height: 100vh;
	background-color: #f5f5f5;
}

/* 自定义导航栏 */
.nav-bar.data-v-1cf27b2a {
	background-color: #1677FF;
	padding: 60rpx 30rpx 24rpx;
	text-align: center;
}
.nav-title.data-v-1cf27b2a {
	color: #fff;
	font-size: 34rpx;
	font-weight: bold;
}

/* 内容区 */
.container.data-v-1cf27b2a {
	padding: 24rpx;
}

/* 顶部宿舍号通栏 */
.dorm-banner.data-v-1cf27b2a {
	background-color: #E6F7FF;
	border-radius: 10px;
	padding: 20rpx 30rpx;
	margin-bottom: 24rpx;
}
.dorm-number.data-v-1cf27b2a {
	font-size: 36rpx;
	font-weight: bold;
	color: #1677FF;
}

/* 欢迎区 */
.welcome-section.data-v-1cf27b2a {
	margin-bottom: 24rpx;
	padding: 0 8rpx;
}
.welcome-text.data-v-1cf27b2a {
	font-size: 30rpx;
	color: #333;
}

/* 公告卡片 */
.notice-card.data-v-1cf27b2a {
	background-color: #fff;
	border: 1rpx solid #eeeeee;
	border-radius: 16rpx;
	padding: 24rpx;
	margin-bottom: 24rpx;
}
.section-header.data-v-1cf27b2a {
	margin-bottom: 16rpx;
}
.section-title.data-v-1cf27b2a {
	font-size: 30rpx;
	font-weight: bold;
	color: #333;
}
.notice-text.data-v-1cf27b2a {
	font-size: 28rpx;
	color: #666;
	line-height: 1.6;
}

/* 待办卡片 */
.todo-card.data-v-1cf27b2a {
	background-color: #fff;
	border: 1rpx solid #eeeeee;
	border-radius: 16rpx;
	padding: 24rpx;
	margin-bottom: 24rpx;
}
.todo-list.data-v-1cf27b2a {
	margin-top: 8rpx;
}
.todo-item.data-v-1cf27b2a {
	display: flex;
	align-items: center;
	padding: 18rpx 0;
	border-bottom: 1rpx solid #f5f5f5;
}
.todo-item.data-v-1cf27b2a:last-child {
	border-bottom: none;
}
.todo-status.data-v-1cf27b2a {
	font-size: 24rpx;
	margin-right: 12rpx;
	flex-shrink: 0;
}
.todo-status.undone.data-v-1cf27b2a {
	color: #fa541c;
}
.todo-status.done.data-v-1cf27b2a {
	color: #52c41a;
}
.todo-text.data-v-1cf27b2a {
	font-size: 28rpx;
	color: #333;
}
.todo-empty.data-v-1cf27b2a {
	text-align: center;
	padding: 40rpx 0;
	color: #999;
	font-size: 28rpx;
}
