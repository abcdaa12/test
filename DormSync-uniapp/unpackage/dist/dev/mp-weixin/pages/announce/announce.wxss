
.container.data-v-fee56dda { min-height: 100vh; background-color: var(--bg-page); padding: 24rpx;
}
.form-card.data-v-fee56dda { margin-top: 24rpx;
}
.form-title.data-v-fee56dda { font-size: 32rpx; font-weight: bold; margin-bottom: 24rpx; color: var(--text-primary);
}
.textarea.data-v-fee56dda { width: 100%; height: 200rpx; background: var(--bg-input); border: 1rpx solid var(--border-color); border-radius: 12rpx; padding: 16rpx; font-size: 28rpx; color: var(--text-primary); margin-bottom: 20rpx; box-sizing: border-box;
}
.section-title.data-v-fee56dda { font-size: 30rpx; font-weight: bold; margin: 32rpx 0 16rpx; color: var(--text-primary);
}
.empty-tip.data-v-fee56dda { text-align: center; padding: 80rpx 0; color: var(--text-placeholder); font-size: 28rpx;
}
.announce-item.data-v-fee56dda { margin-bottom: 16rpx;
}
.announce-header.data-v-fee56dda { display: flex; justify-content: space-between; align-items: center; margin-bottom: 12rpx;
}
.announce-title.data-v-fee56dda { font-size: 30rpx; font-weight: bold; color: var(--text-primary); flex: 1;
}
.announce-read.data-v-fee56dda { font-size: 22rpx; color: var(--color-primary); background: #e6f4ff; padding: 4rpx 16rpx; border-radius: 20rpx; flex-shrink: 0;
}
.dark-mode .announce-read.data-v-fee56dda { background: #1a2a3a;
}
.announce-preview.data-v-fee56dda { font-size: 26rpx; color: var(--text-secondary); display: block; margin-bottom: 12rpx; line-height: 1.5;
}
.announce-footer.data-v-fee56dda { display: flex; justify-content: space-between;
}
.announce-creator.data-v-fee56dda { font-size: 22rpx; color: var(--text-hint);
}
.announce-time.data-v-fee56dda { font-size: 22rpx; color: var(--text-placeholder);
}

/* 弹窗 */
.modal-mask.data-v-fee56dda { position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.5); display: flex; align-items: center; justify-content: center; z-index: 999;
}
.modal-content.data-v-fee56dda { width: 88%; background: var(--bg-card, #fff); border-radius: 20rpx; padding: 36rpx 32rpx; max-height: 80vh; overflow-y: auto;
}
.modal-header.data-v-fee56dda { display: flex; justify-content: space-between; align-items: center; margin-bottom: 24rpx;
}
.modal-title.data-v-fee56dda { font-size: 34rpx; font-weight: bold; color: var(--text-primary); flex: 1;
}
.modal-close.data-v-fee56dda { font-size: 36rpx; color: var(--text-hint); padding: 8rpx 16rpx;
}
.detail-content.data-v-fee56dda { font-size: 28rpx; color: var(--text-primary); line-height: 1.8; display: block; margin-bottom: 20rpx;
}
.detail-meta.data-v-fee56dda { display: flex; justify-content: space-between; margin-bottom: 16rpx;
}
.detail-creator.data-v-fee56dda { font-size: 24rpx; color: var(--text-hint);
}
.detail-time.data-v-fee56dda { font-size: 24rpx; color: var(--text-placeholder);
}
.detail-divider.data-v-fee56dda { height: 1rpx; background: var(--border-light); margin: 16rpx 0;
}
.detail-read-section.data-v-fee56dda { margin-bottom: 20rpx;
}
.detail-read-title.data-v-fee56dda { font-size: 26rpx; color: var(--text-secondary); display: block; margin-bottom: 12rpx;
}
.read-list.data-v-fee56dda { display: flex; flex-wrap: wrap; gap: 12rpx;
}
.read-name.data-v-fee56dda { font-size: 24rpx; color: var(--color-primary); background: #e6f4ff; padding: 6rpx 20rpx; border-radius: 20rpx;
}
.dark-mode .read-name.data-v-fee56dda { background: #1a2a3a;
}
.detail-actions.data-v-fee56dda { text-align: center; padding-top: 16rpx;
}
.delete-link.data-v-fee56dda { font-size: 26rpx; color: #ff4d4f;
}
