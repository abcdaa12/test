
.page.data-v-4c4d1550 { min-height: 100vh; background-color: var(--bg-page);
}
.container.data-v-4c4d1550 { padding: 24rpx;
}

/* 当前宿舍长 */
.current-leader-card.data-v-4c4d1550 { background: linear-gradient(135deg, #1677FF, #4A9FFF); border-radius: 16rpx; padding: 28rpx; margin-bottom: 24rpx;
}
.dark-mode .current-leader-card.data-v-4c4d1550 { background: linear-gradient(135deg, #0d47a1, #1565c0);
}
.card-label.data-v-4c4d1550 { font-size: 24rpx; color: rgba(255,255,255,0.8); display: block; margin-bottom: 8rpx;
}
.leader-name.data-v-4c4d1550 { font-size: 36rpx; font-weight: bold; color: #fff;
}

/* 模式切换 */
.mode-tabs.data-v-4c4d1550 { display: flex; background: var(--bg-card); border-radius: 12rpx; overflow: hidden; margin-bottom: 24rpx; border: 1rpx solid var(--border-color);
}
.mode-tab.data-v-4c4d1550 { flex: 1; text-align: center; padding: 20rpx 0; font-size: 26rpx; color: var(--text-secondary);
}
.mode-tab.active.data-v-4c4d1550 { background: var(--color-primary); color: #fff;
}
.mode-desc.data-v-4c4d1550 { font-size: 26rpx; color: var(--text-hint); display: block; margin-bottom: 20rpx;
}

/* 成员列表 */
.member-item.data-v-4c4d1550 { display: flex; justify-content: space-between; align-items: center; padding: 20rpx; margin-bottom: 12rpx;
}
.member-info.data-v-4c4d1550 { display: flex; align-items: center; gap: 16rpx;
}
.avatar-circle.data-v-4c4d1550 { width: 72rpx; height: 72rpx; border-radius: 50%; background: var(--color-primary); color: #fff; display: flex; align-items: center; justify-content: center; font-size: 30rpx; font-weight: bold;
}
.avatar-circle.small.data-v-4c4d1550 { width: 52rpx; height: 52rpx; font-size: 24rpx;
}
.member-name.data-v-4c4d1550 { font-size: 28rpx; color: var(--text-primary); font-weight: 500;
}
.current-tag.data-v-4c4d1550 { font-size: 24rpx; color: #fa8c16;
}
.elect-btn.data-v-4c4d1550 { font-size: 26rpx; color: var(--color-primary);
}

/* 抽签 */
.lottery-section.data-v-4c4d1550 { text-align: center;
}
.lottery-display.data-v-4c4d1550 { margin: 40rpx 0; padding: 60rpx; background: var(--bg-card); border-radius: 50%; width: 280rpx; height: 280rpx; margin-left: auto; margin-right: auto; display: flex; align-items: center; justify-content: center; border: 4rpx solid var(--color-primary);
}
.lottery-name.data-v-4c4d1550 { font-size: 48rpx; font-weight: bold; color: var(--color-primary);
}
.lottery-name.spinning.data-v-4c4d1550 { animation: pulse-4c4d1550 0.2s infinite;
}
@keyframes pulse-4c4d1550 {
0%,100% { opacity: 1;
}
50% { opacity: 0.4;
}
}
.btn-lottery.data-v-4c4d1550 { width: 60%; height: 80rpx; line-height: 80rpx; background: linear-gradient(135deg, #667eea, #764ba2); color: #fff; border-radius: 40rpx; font-size: 30rpx; border: none; margin: 0 auto;
}
.btn-lottery.data-v-4c4d1550::after { border: none;
}
.lottery-result.data-v-4c4d1550 { margin-top: 32rpx;
}
.result-text.data-v-4c4d1550 { font-size: 34rpx; color: var(--text-primary); font-weight: bold; display: block; margin-bottom: 24rpx;
}
.redraw-btn.data-v-4c4d1550 { font-size: 26rpx; color: var(--text-hint); display: block; text-align: center; margin-top: 16rpx;
}

/* 投票 */
.vote-tip.data-v-4c4d1550 { font-size: 26rpx; color: var(--color-primary); display: block; margin-bottom: 16rpx;
}
.vote-item.data-v-4c4d1550 { display: flex; justify-content: space-between; align-items: center; padding: 20rpx; margin-bottom: 12rpx;
}
.vote-item.data-v-4c4d1550:active { background: var(--bg-hover);
}
.vote-btn.data-v-4c4d1550 { font-size: 26rpx; color: var(--color-primary); font-weight: 500;
}
.vote-results.data-v-4c4d1550 { margin-top: 16rpx;
}
.result-title.data-v-4c4d1550 { font-size: 28rpx; font-weight: bold; color: var(--text-primary); display: block; margin-bottom: 16rpx;
}
.result-row.data-v-4c4d1550 { display: flex; align-items: center; gap: 16rpx; margin-bottom: 16rpx;
}
.result-info.data-v-4c4d1550 { display: flex; align-items: center; gap: 8rpx; width: 160rpx; flex-shrink: 0;
}
.result-name.data-v-4c4d1550 { font-size: 26rpx; color: var(--text-primary);
}
.result-bar-wrap.data-v-4c4d1550 { flex: 1; height: 28rpx; background: var(--bg-input); border-radius: 14rpx; overflow: hidden;
}
.result-bar.data-v-4c4d1550 { height: 100%; background: var(--color-primary); border-radius: 14rpx; transition: width 0.3s;
}
.result-count.data-v-4c4d1550 { font-size: 24rpx; color: var(--text-hint); width: 80rpx; text-align: right; flex-shrink: 0;
}
.winner-section.data-v-4c4d1550 { text-align: center; margin-top: 32rpx; padding: 24rpx; background: #f6ffed; border-radius: 16rpx;
}
.dark-mode .winner-section.data-v-4c4d1550 { background: #1a2a1a;
}
.winner-text.data-v-4c4d1550 { font-size: 32rpx; font-weight: bold; color: #52c41a; display: block; margin-bottom: 8rpx;
}
.tie-text.data-v-4c4d1550 { font-size: 24rpx; color: #fa8c16; display: block; margin-bottom: 16rpx;
}
.waiting-tip.data-v-4c4d1550 { text-align: center; padding: 24rpx; color: var(--text-hint); font-size: 26rpx;
}
.btn-end-vote.data-v-4c4d1550 { width: 60%; height: 76rpx; line-height: 76rpx; background: #fa8c16; color: #fff; border-radius: 12rpx; font-size: 28rpx; border: none; margin: 16rpx auto 0;
}
.btn-end-vote.data-v-4c4d1550::after { border: none;
}
