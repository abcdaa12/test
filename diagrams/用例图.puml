@startuml
left to right direction
skinparam packageStyle rectangle
skinparam usecase {
  BackgroundColor #F5F5F5
  BorderColor #333333
  FontSize 13
}
skinparam actor {
  FontSize 14
}

actor "普通用户" as user
actor "宿舍成员" as member
actor "宿舍长" as leader

rectangle "DormSync 宿舍协同管理系统" {
  usecase "微信登录" as UC1
  usecase "个人信息管理" as UC2
  usecase "创建宿舍" as UC3
  usecase "加入宿舍" as UC4
  usecase "夜间模式" as UC13
  usecase "语言切换" as UC12

  usecase "查看成员列表" as UC11
  usecase "消息中心" as UC10
  usecase "查看公告" as UC9
  usecase "排班管理" as UC8
  usecase "投票决策" as UC7
  usecase "费用管理" as UC6
  usecase "待办事项管理" as UC5

  usecase "发布公告" as UC14
  usecase "删除公告" as UC15
  usecase "宿舍长选举" as UC16
  usecase "邀请成员" as UC17

  usecase "AI智能排班" as UC18
  usecase "批量排班操作" as UC19
  usecase "财务数据可视化" as UC20
  usecase "实时消息推送" as UC21

  UC8 <.. UC18 : <<extend>>
  UC8 <.. UC19 : <<extend>>
  UC6 <.. UC20 : <<extend>>
  UC10 <.. UC21 : <<extend>>
}

member -up-|> user
leader -up-|> member

user --> UC1
user --> UC2
user --> UC3
user --> UC4
user --> UC13
user --> UC12

member --> UC11
member --> UC10
member --> UC9
member --> UC8
member --> UC7
member --> UC6
member --> UC5

leader --> UC14
leader --> UC15
leader --> UC16
leader --> UC17
@enduml