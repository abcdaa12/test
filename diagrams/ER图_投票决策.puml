@startuml
skinparam linetype ortho
skinparam nodesep 50
skinparam ranksep 50

entity "宿舍 Dorm" as Dorm {
  * _id : ObjectId
  --
  dormNumber : String
  notice : String
  members : ObjectId[]
}

entity "用户 User" as User {
  * _id : ObjectId
  --
  openid : String
  nickname : String
  dormId : ObjectId
}

entity "投票决策 Decision" as Decision {
  * _id : ObjectId
  --
  dormId : ObjectId
  title : String
  options : Array
  voters : Array
  deadline : Date
  creatorId : ObjectId
}

Dorm ||--o{ Decision : 发起 (1:N)
User ||--o{ Decision : 创建 (1:N)
User ||--o{ Decision : 参与投票 (M:N)

@enduml